{
  "name": "mcp-ask-user-question",
  "version": "1.0.0",
  "description": "Protocol-first MCP server exposing an AskUserQuestion-compatible tool.",
  "type": "module",
  "bin": {
    "mcp-ask-user-question": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
