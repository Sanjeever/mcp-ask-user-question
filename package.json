  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sanjeever/mcp-ask-user-question.git"
  },
  "bugs": {
    "url": "https://github.com/Sanjeever/mcp-ask-user-question/issues"
  },
  "homepage": "https://github.com/Sanjeever/mcp-ask-user-question#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
